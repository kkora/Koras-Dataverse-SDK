root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.{json,yml,yaml,props,targets,csproj,sln,slnx,config,xml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.cs]
# Style
csharp_style_namespace_declarations = file_scoped:error
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = true:suggestion
csharp_prefer_braces = true:warning
csharp_style_prefer_primary_constructors = true:suggestion
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = true:suggestion
csharp_using_directive_placement = outside_namespace:error
dotnet_sort_system_directives_first = true
dotnet_style_qualification_for_field = false:warning
dotnet_style_require_accessibility_modifiers = for_non_interface_members:error
dotnet_style_readonly_field = true:warning

# Naming: private const and static readonly fields are PascalCase; other private fields _camelCase
dotnet_naming_rule.private_constants_pascal.symbols = private_constants
dotnet_naming_rule.private_constants_pascal.style = pascal_case_style
dotnet_naming_rule.private_constants_pascal.severity = warning
dotnet_naming_symbols.private_constants.applicable_kinds = field
dotnet_naming_symbols.private_constants.applicable_accessibilities = private
dotnet_naming_symbols.private_constants.required_modifiers = const

dotnet_naming_rule.private_static_readonly_pascal.symbols = private_static_readonly
dotnet_naming_rule.private_static_readonly_pascal.style = pascal_case_style
dotnet_naming_rule.private_static_readonly_pascal.severity = warning
dotnet_naming_symbols.private_static_readonly.applicable_kinds = field
dotnet_naming_symbols.private_static_readonly.applicable_accessibilities = private
dotnet_naming_symbols.private_static_readonly.required_modifiers = static, readonly

dotnet_naming_rule.private_fields_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_underscore.style = underscore_camel
dotnet_naming_rule.private_fields_underscore.severity = warning
dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_style.underscore_camel.capitalization = camel_case
dotnet_naming_style.underscore_camel.required_prefix = _
dotnet_naming_style.pascal_case_style.capitalization = pascal_case

# Analyzer tuning
dotnet_diagnostic.CA1848.severity = none        # LoggerMessage source-gen: adopted selectively on hot paths
dotnet_diagnostic.CA1032.severity = none        # standard exception constructors: DataverseException requires an error
dotnet_diagnostic.CA1062.severity = none        # nullable reference types cover public null validation
dotnet_diagnostic.CA2234.severity = none        # string URIs are idiomatic for relative Web API paths

# Public API tracking (ADR-0010): suggestion until 1.0, then error.
dotnet_diagnostic.RS0016.severity = suggestion  # symbol not documented in PublicAPI files
dotnet_diagnostic.RS0017.severity = suggestion
dotnet_diagnostic.RS0024.severity = suggestion
dotnet_diagnostic.RS0025.severity = suggestion
dotnet_diagnostic.RS0026.severity = suggestion
dotnet_diagnostic.RS0027.severity = suggestion
dotnet_diagnostic.RS0036.severity = suggestion
dotnet_diagnostic.RS0037.severity = suggestion
dotnet_diagnostic.RS0041.severity = suggestion
dotnet_diagnostic.RS0048.severity = suggestion
